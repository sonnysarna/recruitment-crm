# ============================================================
#  Recruitment CRM — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to git
# ============================================================

# ── App ───────────────────────────────────────────────────
APP_HOST=yourcompany.com          # Your domain (no https://)
ALLOWED_ORIGINS=https://yourcompany.com,https://api.yourcompany.com

# ── Database ──────────────────────────────────────────────
DB_ROOT_PASSWORD=change_me_root_password_strong
DB_NAME=recruitment_crm
DB_USER=recruit_user
DB_PASSWORD=change_me_db_password_strong

# ── SuiteCRM Admin ────────────────────────────────────────
SUITECRM_ADMIN_USER=admin
SUITECRM_ADMIN_PASSWORD=change_me_suitecrm_password_strong
SUITECRM_ADMIN_EMAIL=admin@yourcompany.com

# ── SuiteCRM API OAuth2 Client ────────────────────────────
# Create this in SuiteCRM: Admin > OAuth2 Clients
# After first setup, generate a client and paste IDs here
SUITECRM_API_CLIENT_ID=your_oauth2_client_id
SUITECRM_API_CLIENT_SECRET=your_oauth2_client_secret

# ── JWT (Our API Layer) ───────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_EXPIRES_IN=8h

# ── AI Matching (Optional) ────────────────────────────────
# Add your OpenAI key to enable AI candidate scoring
OPENAI_API_KEY=sk-...
